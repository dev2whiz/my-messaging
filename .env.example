# ── Postgres ──────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=msguser
POSTGRES_PASSWORD=msgpassword
POSTGRES_DB=messaging

# ── Valkey ────────────────────────────────────────────────────
VALKEY_HOST=valkey
VALKEY_PORT=6379

# ── RabbitMQ ──────────────────────────────────────────────────
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# ── Gateway ───────────────────────────────────────────────────
JWT_SECRET=supersecretkeythatisatleast32byteslong
JWT_EXPIRATION=86400000

# ── CORS ──────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173
